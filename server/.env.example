# Vyom — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB — Use MongoDB Atlas cloud connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/vyom

# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

LOG_LEVEL=info

# Python AI engine URL
AI_ENGINE_URL=http://127.0.0.1:8000
